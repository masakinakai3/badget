{
    "name": "budgetmaster-server-exe",
    "version": "1.0.0",
    "description": "BudgetMaster Server-only EXE",
    "main": "backend/dist/index.js",
    "bin": "backend/dist/index.js",
    "scripts": {
        "build:frontend": "cd frontend && npm run build",
        "build:backend": "cd backend && npm run build",
        "build:exe": "npm run build:frontend && npm run build:backend && pkg . --targets node18-win-x64 --output dist/BudgetMaster.exe && node -e \"require('fs').copyFileSync('backend/node_modules/sqlite3/build/Release/node_sqlite3.node', 'dist/node_sqlite3.node')\""
    },
    "pkg": {
        "assets": [
            "frontend/dist/**/*",
            "backend/node_modules/sqlite3/build/Release/node_sqlite3.node"
        ],
        "scripts": [
            "backend/dist/**/*.js"
        ]
    },
    "devDependencies": {
        "pkg": "^5.8.1"
    }
}